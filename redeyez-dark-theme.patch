+
+/* ═══════════════════════════════════════════
+   NIGHT FIELD GUIDE — atmosphere signature
+   One fixed smoke field: warm haze top, ember
+   breath low. Everything else stays disciplined.
+   ═══════════════════════════════════════════ */
+body::before {
+  content: "";
+  position: fixed;
+  inset: 0;
+  z-index: 0;
+  pointer-events: none;
+  background:
+    radial-gradient(ellipse 90% 52% at 76% -6%, rgba(194,168,120,0.055), transparent 60%),
+    radial-gradient(ellipse 72% 44% at 12% 108%, rgba(226,52,56,0.05), transparent 58%);
+}
+body > * {
+  position: relative;
+  z-index: 1;
+}
+
+::selection {
+  background: rgba(226,52,56,0.85);
+  color: #F5F0E6;
+}
+
+/* Reduce heavy raster edges on dark: soften imagery into the smoke */
+.platform-card img,
+.map-city-picker-card img {
+  filter: saturate(0.96) contrast(1.02);
+}
