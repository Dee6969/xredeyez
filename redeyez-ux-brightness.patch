@@ -9592,3 +9592,35 @@ body > * {
 .map-city-picker-card img {
   filter: saturate(0.96) contrast(1.02);
 }
+
+
+/* Light Voyager tiles inside dark chrome: soft warm dim, full readability */
+.platform-leaflet-map .leaflet-tile-pane,
+.network-map-canvas .leaflet-tile-pane,
+.home-leaflet-map .leaflet-tile-pane {
+  filter: brightness(0.95) saturate(0.94) sepia(0.05);
+}
+
+/* ═══════════════════════════════════════════
+   DARK THEME QUALITY FLOOR
+   ═══════════════════════════════════════════ */
+
+/* Form fields: visible placeholders, clear focus */
+.claim-form input::placeholder,
+.claim-form textarea::placeholder,
+input::placeholder,
+textarea::placeholder {
+  color: rgba(245,240,230,0.38);
+}
+
+/* Keyboard focus visible everywhere on dark */
+a:focus-visible,
+button:focus-visible,
+input:focus-visible,
+select:focus-visible,
+textarea:focus-visible,
+[data-hover]:focus-visible {
+  outline: 2px solid rgba(226,52,56,0.85);
+  outline-offset: 2px;
+  border-radius: 4px;
+}
-- 
