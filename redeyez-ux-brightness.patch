From cd5642d87c1379f5fd362feaf1961fa21af3d547 Mon Sep 17 00:00:00 2001
From: Claude <claude@anthropic.com>
Date: Thu, 2 Jul 2026 18:47:29 +0000
Subject: [PATCH] UX pass: lift theme brightness, readable Voyager map tiles
 with warm dim, glass panel separation, gold/featured fixes, focus +
 placeholder quality floor

---
 app/data/geo.ts |   4 +-
 app/globals.css | 112 +++++++++++++++++++++++++++++++-----------------
 2 files changed, 74 insertions(+), 42 deletions(-)

diff --git a/app/data/geo.ts b/app/data/geo.ts
index fc142c0..b9cb651 100644
--- a/app/data/geo.ts
+++ b/app/data/geo.ts
@@ -21,13 +21,13 @@ export function getTileConfig(): { url: string; attribution: string; maxZoom: nu
   const maptilerKey = process.env.NEXT_PUBLIC_MAPTILER_KEY;
   if (maptilerKey) {
     return {
-      url: `https://api.maptiler.com/maps/streets-v2-dark/{z}/{x}/{y}{r}.png?key=${maptilerKey}`,
+      url: `https://api.maptiler.com/maps/streets-v2/{z}/{x}/{y}{r}.png?key=${maptilerKey}`,
       attribution: '&copy; <a href="https://www.maptiler.com/">MapTiler</a> &copy; OpenStreetMap contributors',
       maxZoom: 20,
     };
   }
   return {
-    url: "https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png",
+    url: "https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png",
     attribution: '&copy; OpenStreetMap contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
     maxZoom: 20,
   };
